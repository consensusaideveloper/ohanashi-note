{
  "name": "ohanashi-ending-note",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm --prefix client run dev\" \"npm --prefix server run dev\"",
    "build": "npm --prefix client run build && npm --prefix server run build",
    "prestart": "test -f server/dist/index.js || npm --prefix server run build",
    "start": "node server/dist/index.js",
    "db:migrate": "npm --prefix server run db:migrate",
    "db:migrate:status": "npm --prefix server run db:migrate:status",
    "db:migrate:baseline": "npm --prefix server run db:migrate:baseline",
    "lint": "eslint .",
    "typecheck": "npm --prefix client run typecheck && npm --prefix server run typecheck",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test",
    "screenshot": "playwright test e2e/screenshot.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-validate-jsx-nesting": "^0.1.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "lightningcss-linux-x64-gnu": "1.31.1"
  }
}
