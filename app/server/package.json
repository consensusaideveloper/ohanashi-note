{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "lsof -ti :3000 | xargs kill -9 2>/dev/null || true",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "db:migrate": "node scripts/migrations.mjs apply",
    "db:migrate:status": "node scripts/migrations.mjs status",
    "db:migrate:baseline": "node scripts/migrations.mjs baseline",
    "summaries:requeue-failed": "node scripts/requeue-failed-summaries.mjs",
    "summaries:repair-one": "tsx scripts/repair-conversation-summary.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@aws-sdk/s3-request-presigner": "^3.998.0",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.1.0",
    "archiver": "^7.0.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "firebase-admin": "^13.6.1",
    "hono": "^4.7.0",
    "openai": "^6.24.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
